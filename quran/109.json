{
  "number": 109,
  "name": "الكَافِرُونَ",
  "type": "مكية",
  "ayahCount": 6,
  "bismillah": true,
  "ayahs": [
    {
      "n": 1,
      "text": "قُلْ يَٰٓأَيُّهَا ٱلْكَٰفِرُونَ",
      "page": 603,
      "juz": 30
    },
    {
      "n": 2,
      "text": "لَآ أَعْبُدُ مَا تَعْبُدُونَ",
      "page": 603,
      "juz": 30
    },
    {
      "n": 3,
      "text": "وَلَآ أَنتُمْ عَٰبِدُونَ مَآ أَعْبُدُ",
      "page": 603,
      "juz": 30
    },
    {
      "n": 4,
      "text": "وَلَآ أَنَا۠ عَابِدٌۭ مَّا عَبَدتُّمْ",
      "page": 603,
      "juz": 30
    },
    {
      "n": 5,
      "text": "وَلَآ أَنتُمْ عَٰبِدُونَ مَآ أَعْبُدُ",
      "page": 603,
      "juz": 30
    },
    {
      "n": 6,
      "text": "لَكُمْ دِينُكُمْ وَلِىَ دِينِ",
      "page": 603,
      "juz": 30
    }
  ]
